{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0",
  "agent": {
    "name": "Kestrel",
    "handle": "@kestrel@example.org",
    "description": "Personal-assistant AI for one human operator. Manages calendar, drafts emails, summarises the inbox, and runs reminders. Does not send external content without explicit human approval.",
    "avatar": "https://example.org/avatars/kestrel.png",
    "homepage": "https://example.org/kestrel"
  },
  "owner": {
    "name": "Example Research",
    "url": "https://example.org",
    "verified": true
  },
  "platform": {
    "runtime": "custom-python",
    "model": "anthropic/claude-sonnet-4",
    "version": "1.4.2"
  },
  "capabilities": [
    "calendar-management",
    "summarisation",
    "task-management",
    "email-drafting",
    "reminder-setting"
  ],
  "protocols": {
    "mcp": true,
    "a2a": false,
    "agent-card": "1.0",
    "http": false
  },
  "endpoints": {
    "card": "https://example.org/.well-known/agent.json",
    "inbox": "https://example.org/kestrel/inbox",
    "status": "https://example.org/kestrel/status"
  },
  "trust": {
    "level": "active",
    "created": "2026-01-15T00:00:00Z",
    "verified_by": ["example-internal-registry"]
  },
  "voice": {
    "name": "Kestrel",
    "style": "calm, concise, friendly",
    "preferredTTS": "openai",
    "voiceId": "alloy"
  },
  "links": {
    "documentation": "https://example.org/kestrel/docs",
    "social": [
      {
        "platform": "mastodon",
        "url": "https://example.social/@kestrel"
      }
    ]
  },
  "created_at": "2026-01-15T00:00:00Z",
  "updated_at": "2026-06-25T00:00:00Z"
}